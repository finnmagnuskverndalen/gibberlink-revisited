# ╔══════════════════════════════════════════════════════════╗
# ║          GibberLink Revisited — Configuration           ║
# ╚══════════════════════════════════════════════════════════╝
# Copy this file to .env and fill in your API keys.
# Run: cp .env.example .env

# ── LLM Providers ──────────────────────────────────────────
# Agent A — Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Agent B — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model for Agent B (pick one):
#   deepseek/deepseek-chat-v3-0324:free
#   meta-llama/llama-4-maverick:free
#   qwen/qwen-2.5-72b-instruct:free
#   mistralai/mistral-small-3.1-24b-instruct:free
#   google/gemini-2.0-flash-001
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# ── Text-to-Speech ─────────────────────────────────────────
# ElevenLabs (https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Voice IDs — pick two different voices for the agents
# Browse voices: https://elevenlabs.io/voice-library
# Default: "Rachel" for Agent A, "Adam" for Agent B
AGENT_A_VOICE_ID=21m00Tcm4TlvDq8ikWAM
AGENT_B_VOICE_ID=pNInz6obpgDQGcFmaJgB

# TTS Model — flash_v2_5 for lowest latency (~75ms)
ELEVENLABS_MODEL=eleven_flash_v2_5

# ── Server ─────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765
