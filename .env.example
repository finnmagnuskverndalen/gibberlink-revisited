# ╔══════════════════════════════════════════════════════════╗
# ║          GibberLink Revisited — Configuration           ║
# ╚══════════════════════════════════════════════════════════╝
# TIP: Run `python3 setup.py` to configure interactively.
# Or copy this file to .env and fill in manually:  cp .env.example .env

# ── Agent A — Voss (strategist) ──────────────────────────────
AGENT_A_PROVIDER=openrouter
AGENT_A_API_KEY=sk-or-v1-your-key-here
AGENT_A_MODEL=deepseek/deepseek-chat-v3-0324:free

# ── Agent B — Lyra (creative) ───────────────────────────────
AGENT_B_PROVIDER=openrouter
AGENT_B_API_KEY=sk-or-v1-your-key-here
AGENT_B_MODEL=meta-llama/llama-4-maverick:free

# ── Agent C — Kael (skeptic) ────────────────────────────────
AGENT_C_PROVIDER=openrouter
AGENT_C_API_KEY=sk-or-v1-your-key-here
AGENT_C_MODEL=google/gemini-2.0-flash-exp:free

# ── Agent D — Iris (synthesizer) ─────────────────────────────
AGENT_D_PROVIDER=openrouter
AGENT_D_API_KEY=sk-or-v1-your-key-here
AGENT_D_MODEL=mistralai/mistral-small-3.1-24b-instruct:free

# ── Chairman — Nexus ────────────────────────────────────────
CHAIRMAN_PROVIDER=openrouter
CHAIRMAN_API_KEY=sk-or-v1-your-key-here
CHAIRMAN_MODEL=deepseek/deepseek-chat-v3-0324:free

# NOTE: If all agents use the same provider, you only need one API key.
# Just paste the same key for all AGENT_*_API_KEY and CHAIRMAN_API_KEY fields.
#
# Supported providers: openrouter, anthropic, openai, gemini, grok
# Free models on OpenRouter:
#   deepseek/deepseek-chat-v3-0324:free
#   meta-llama/llama-4-maverick:free
#   google/gemini-2.0-flash-exp:free
#   mistralai/mistral-small-3.1-24b-instruct:free

# ── Text-to-Speech ─────────────────────────────────────────
# Pick one: elevenlabs | kokoro | qwen3 | none
TTS_PROVIDER=none

# --- ElevenLabs (cloud, highest quality) ---
# Get key at: https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=your-key-here
# ELEVENLABS_MODEL=eleven_flash_v2_5
# AGENT_A_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# AGENT_B_VOICE_ID=pNInz6obpgDQGcFmaJgB
# AGENT_C_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# AGENT_D_VOICE_ID=pNInz6obpgDQGcFmaJgB
# CHAIRMAN_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Kokoro (local, free, fast CPU) ---
# KOKORO_TTS_URL=http://localhost:7862
# AGENT_A_KOKORO_VOICE=am_michael
# AGENT_B_KOKORO_VOICE=bm_george
# AGENT_C_KOKORO_VOICE=am_adam
# AGENT_D_KOKORO_VOICE=bm_lewis
# CHAIRMAN_KOKORO_VOICE=am_echo

# --- Qwen3-TTS (local, free, needs more RAM) ---
# QWEN3_TTS_URL=http://localhost:7861
# AGENT_A_QWEN3_VOICE=Ryan
# AGENT_B_QWEN3_VOICE=Ethan
# AGENT_C_QWEN3_VOICE=Miles
# AGENT_D_QWEN3_VOICE=Leo
# CHAIRMAN_QWEN3_VOICE=Axel

# ── Server ─────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765
